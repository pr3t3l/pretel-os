[Unit]
Description=pretel-os Telegram bot
After=network-online.target postgresql.service pretel-os-mcp.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pretel/dev/pretel-os
Environment=PYTHONPATH=/home/pretel/dev/pretel-os/src
EnvironmentFile=/home/pretel/.env.pretel_os
ExecStart=/home/pretel/.venvs/pretel-os/bin/python -m telegram_bot
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
