# Anthropic
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_API_KEY_ROUTER=<your-anthropic-api-key-router>
ANTHROPIC_API_KEY_REFLECTION=<your-anthropic-api-key-reflection>

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# LiteLLM proxy (local)
LITELLM_URL=http://127.0.0.1:4000
LITELLM_API_KEY=<your-litellm-local-key>

# Postgres
DATABASE_URL=postgresql://pretel_os:<password>@127.0.0.1:5432/pretel_os
DATABASE_POOL_SIZE=10

# n8n
N8N_URL=http://127.0.0.1:5678
N8N_API_KEY=<your-n8n-api-key>

# Telegram
TELEGRAM_BOT_TOKEN=<bot-id>:<bot-token>
TELEGRAM_OPERATOR_CHAT_ID=<your-chat-id>

# Supabase (Phase 4+; empty in Phase 1-3)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# MCP server config
MCP_SERVER_PORT=8787
MCP_SERVER_HOST=0.0.0.0
MCP_LOG_LEVEL=INFO
MCP_SHARED_SECRET=<random-48-char-secret>

# Timeouts (milliseconds)
TIMEOUT_HAIKU_MS=3000
TIMEOUT_OPUS_MS=60000
TIMEOUT_SONNET_MS=30000
TIMEOUT_OPENAI_EMBEDDING_MS=5000
TIMEOUT_N8N_WEBHOOK_MS=10000
TIMEOUT_SUPABASE_MS=5000
TIMEOUT_LITELLM_SECOND_OPINION_MS=15000
